                        "type": "string",
                        "format": "email",
                        "title": "Email address",
                        "maxLength": 254
                    },
                    "faculty_profile": {
                        "$ref": "#/components/schemas/FacultyProfile"
                    }
                },
                "required": [
                    "college_id",
                    "email",
                    "faculty_profile",
                    "first_name",
                    "id",
                    "last_name"
                ]
            },
            "FacultyProfile": {
