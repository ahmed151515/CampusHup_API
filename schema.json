                        "type": "string",
                        "description": "Student: 202603001 | Faculty: DR001 | Admin: ADMIN01",
                        "maxLength": 30
                    },
                    "first_name": {
                        "type": "string",
                        "maxLength": 150
                    },
                    "last_name": {
                        "type": "string",
                        "maxLength": 150
                    },
